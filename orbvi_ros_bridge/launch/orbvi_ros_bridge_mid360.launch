<launch>
  <!-- Visual raw-data entry plus MID360 point cloud and MID360 IMU. -->
  <arg name="host" default="127.0.0.1" doc="ORBVI device IP or hostname"/>
  <arg name="control_port" default="18088" doc="ORBVI Host SDK control port"/>
  <arg name="connect_timeout_ms" default="2000" doc="ORBVI Host SDK initial connect timeout per attempt"/>
  <arg name="connect_retry_count" default="4" doc="Initial Host SDK connect retries after the first failed attempt"/>
  <arg name="connect_retry_delay_ms" default="1000" doc="Delay between initial Host SDK connect attempts"/>
  <arg name="streams" default="raw,rectified,imu,lidar,lidar_imu,disparity,depth,vio" doc="Comma-separated stream list. Include pano to publish Host-derived panorama."/>
  <arg name="pano_config" default="$(find orbvi_ros_bridge)/config/pano_mode2.yaml" doc="Host SDK panorama parameter YAML. Default is mode 2 with 32 px seam blend."/>

  <node pkg="orbvi_ros_bridge" type="orbvi_ros_bridge_node" name="orbvi_ros_bridge" output="screen">
    <param name="host" value="$(arg host)"/>
    <param name="control_port" value="$(arg control_port)"/>
    <param name="connect_timeout_ms" value="$(arg connect_timeout_ms)"/>
    <param name="connect_retry_count" value="$(arg connect_retry_count)"/>
    <param name="connect_retry_delay_ms" value="$(arg connect_retry_delay_ms)"/>
    <param name="streams" value="$(arg streams)"/>
    <param name="topic_prefix" value="/orbvi"/>
    <rosparam command="load" file="$(arg pano_config)"/>
  </node>
</launch>
