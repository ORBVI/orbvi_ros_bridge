<launch>
  <arg name="host" default="127.0.0.1"/>
  <arg name="control_port" default="18088"/>
  <arg name="topic_prefix" default="/orbvi"/>
  <arg name="require_streaming_transport" default="true"/>
  <arg name="allow_sample_endpoint_fallback" default="false"/>
  <arg name="queue_size" default="4"/>
  <arg name="max_receive_queue_depth" default="8"/>
  <arg name="first_frame_timeout_ms" default="5000"/>

  <include file="$(find orbvi_ros_bridge)/launch/orbvi_ros_bridge.launch">
    <arg name="host" value="$(arg host)"/>
    <arg name="control_port" value="$(arg control_port)"/>
    <arg name="streams" value="lidar,lidar_imu"/>
    <arg name="topic_prefix" value="$(arg topic_prefix)"/>
    <arg name="require_streaming_transport" value="$(arg require_streaming_transport)"/>
    <arg name="allow_sample_endpoint_fallback" value="$(arg allow_sample_endpoint_fallback)"/>
    <arg name="image_mode" value="raw-only"/>
    <arg name="queue_size" value="$(arg queue_size)"/>
    <arg name="max_receive_queue_depth" value="$(arg max_receive_queue_depth)"/>
    <arg name="max_decode_queue_depth" value="1"/>
    <arg name="first_frame_timeout_ms" value="$(arg first_frame_timeout_ms)"/>
    <arg name="publish_depth" value="false"/>
    <arg name="publish_depth_viz" value="false"/>
    <arg name="publish_depth_pointcloud" value="false"/>
  </include>
</launch>
